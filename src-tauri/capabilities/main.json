{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Allows the main OPJRD window to use the core APIs needed by the browser-first experiment shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write-text-file"
  ]
}
